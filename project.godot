; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Planetary Pastures"
run/main_scene="uid://ciyjck8omac7h"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

DevkitMessenger="*uid://cr5t358qfaup"
SignalLens="*uid://85rkx60vm7a7"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/resizable=false
window/size/borderless=true
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"
mouse_cursor/custom_image="uid://co3h84ppvxcms"

[editor]

movie_writer/movie_file="/home/prncssclr/Documents/Planetary-Pastures/planetary-pastures/VideoCaps/rec.mp4.avi"
movie_writer/fps=30

[editor_plugins]

enabled=PackedStringArray("res://addons/signal_lens/plugin.cfg", "res://addons/steam_devkit_notifier/plugin.cfg")

[file_customization]

folder_colors={
"res://src/Scenes/": "red",
"res://src/Sub-Scenes/": "orange",
"res://src/Sub-Scenes/Little Green/": "pink",
"res://src/Sub-Scenes/Plants/": "green"
}

[global_group]

GardenPlots=""
LittleGreen=""

[input]

QUIT={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":true,"meta_pressed":false,"pressed":false,"keycode":81,"physical_keycode":0,"key_label":0,"unicode":113,"location":0,"echo":false,"script":null)
]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
